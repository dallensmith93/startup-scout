{
  "name": "startup-scout",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "dev:api": "uvicorn app.main:app --reload --app-dir apps/api",
    "test:api": "python -m pytest apps/api/tests -q"
  }
}
